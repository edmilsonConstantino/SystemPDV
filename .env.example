# --- Modo local sem Docker (recomendado para dev) ---
# Postgres embutido em ficheiro em ./data/pglite-dev — não precisa de servidor Postgres.
DATABASE_URL=pglite:./data/pglite-dev

# --- Ou Postgres remoto / Docker / nativo ---
# DATABASE_URL=postgresql://makira:makira@localhost:5432/makira
# DATABASE_URL=postgresql://makira:makira@localhost:5433/makira

SESSION_SECRET=altere-em-producao

# Opcional: senha inicial do admin + vendedor demo (em dev o default é admin123)
# ADMIN_SEED_PASSWORD=

# Ao arrancar em desenvolvimento o servidor cria: admin, gestor, vendedor, categorias e produtos.
# Para repor tudo do zero (PGlite): apague a pasta ./data/pglite-dev e reinicie.
